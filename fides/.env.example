# ────────────────────────────────────────────────
# Fides — variabili d'ambiente
# Copia questo file in .env e compila i valori reali
# NON committare .env nel repository
# ────────────────────────────────────────────────

# Database (Supabase PostgreSQL)
# Aggiungi ?pgbouncer=true&connection_limit=1 per il free tier Supabase
DATABASE_URL=postgresql://user:password@host:5432/fides?pgbouncer=true&connection_limit=1

# Flask
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-questo-con-un-valore-casuale-sicuro
FLASK_ENV=development

# Admin (credenziali separate dal DB utenti)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-questo-con-password-sicura

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=digest@fides.app

# URL pubblico dell'app (usato nei link delle email)
APP_URL=https://fides.onrender.com

# Script blog monitor (opzionale — default: ../blog_monitor_v2.py)
# BLOG_MONITOR_SCRIPT=/percorso/assoluto/blog_monitor_v2.py

# Anthropic (per blog_monitor_v2.py)
ANTHROPIC_API_KEY=sk-ant-...
